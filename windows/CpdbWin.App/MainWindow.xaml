<Window x:Class="CpdbWin.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:CpdbWin.App">
    <Grid Padding="12" RowDefinitions="Auto,*,Auto" RowSpacing="8">
        <TextBox x:Name="SearchBox"
                 PlaceholderText="Search clipboard history…"
                 TextChanged="SearchBox_TextChanged"
                 KeyDown="SearchBox_KeyDown"/>

        <Grid Grid.Row="1" ColumnDefinitions="2*,3*" ColumnSpacing="12">
            <ListView x:Name="EntryList"
                      Grid.Column="0"
                      IsItemClickEnabled="True"
                      ItemClick="EntryList_ItemClick"
                      SelectionChanged="EntryList_SelectionChanged"
                      KeyDown="EntryList_KeyDown"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:EntryViewModel">
                        <Grid ColumnDefinitions="48,*" ColumnSpacing="10" Margin="0,4">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Delete" Click="DeleteMenuItem_Click">
                                        <MenuFlyoutItem.Icon>
                                            <SymbolIcon Symbol="Delete"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Border Width="48" Height="48"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="4">
                                <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Subtitle}" Opacity="0.6" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Column="1"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="4"
                    Padding="12">
                <Grid RowDefinitions="*,Auto" RowSpacing="8">
                    <Grid Grid.Row="0">
                        <ScrollViewer x:Name="DetailTextScroll" Visibility="Collapsed">
                            <TextBlock x:Name="DetailText"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"
                                       FontFamily="Consolas"/>
                        </ScrollViewer>
                        <Image x:Name="DetailImage" Visibility="Collapsed" Stretch="Uniform"/>
                        <TextBlock x:Name="DetailEmpty"
                                   Text="Select an entry to preview"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel x:Name="DetailMeta" Grid.Row="1" Visibility="Collapsed" Spacing="2">
                        <HyperlinkButton x:Name="DetailSourceUrl"
                                         Visibility="Collapsed"
                                         Padding="0"
                                         FontSize="12"/>
                        <HyperlinkButton x:Name="DetailPageUrl"
                                         Visibility="Collapsed"
                                         Padding="0"
                                         FontSize="12"/>
                        <TextBlock x:Name="DetailHtmlNote"
                                   Visibility="Collapsed"
                                   Opacity="0.6"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Opacity="0.5" FontSize="11"/>
    </Grid>
</Window>
